struct first {
    int a,b,c,g,d;
    char s;
};


struct second {
    char s;
    struct first a;
};

struct second aled(int a,struct first b){
    struct second a ;
    a.s = 'a';
    a.a = b;
    return a;

}

int main(void){
    struct first a ;
    a.a =   63;
    if( a.a > 5){
        return 5 ;
    } 

    return 0;
}